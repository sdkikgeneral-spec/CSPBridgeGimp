# Doxyfile — CSPBridgeGimp

#---------------------------------------------------------------------------
# プロジェクト情報
#---------------------------------------------------------------------------
PROJECT_NAME           = "CSPBridgeGimp"
PROJECT_BRIEF          = "CSP × GIMP プラグインブリッジ ホストエミュレーター"
PROJECT_NUMBER         = 0.1.0
OUTPUT_DIRECTORY       = docs/doxygen
OUTPUT_LANGUAGE        = Japanese

#---------------------------------------------------------------------------
# 入力
#---------------------------------------------------------------------------
INPUT                  = src
RECURSIVE              = YES
FILE_PATTERNS          = *.cpp *.h
EXCLUDE_PATTERNS       = */subprojects/* */build/*

#---------------------------------------------------------------------------
# 抽出設定
#---------------------------------------------------------------------------
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

#---------------------------------------------------------------------------
# コメントスタイル（/** */ および /// に対応）
#---------------------------------------------------------------------------
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO

#---------------------------------------------------------------------------
# 出力形式
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# 図・グラフ（Graphviz が必要）
#---------------------------------------------------------------------------
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_DIAGRAMS         = YES
